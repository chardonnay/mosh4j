%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#2d3436",
    "primaryTextColor": "#dfe6e9",
    "primaryBorderColor": "#636e72",
    "lineColor": "#b2bec3",
    "fontFamily": "Menlo, Consolas, monospace",
    "fontSize": "13px"
  },
  "flowchart": {
    "nodeSpacing": 16,
    "rankSpacing": 32,
    "curve": "linear",
    "padding": 10
  }
}}%%

graph TD
    classDef appLayer   fill:#00b894,stroke:#55efc4,color:#2d3436,stroke-width:2px
    classDef protoLayer fill:#0984e3,stroke:#74b9ff,color:#dfe6e9,stroke-width:2px
    classDef fragLayer  fill:#e17055,stroke:#fab1a0,color:#2d3436,stroke-width:2px
    classDef sspLayer   fill:#d63031,stroke:#ff7675,color:#dfe6e9,stroke-width:2px
    classDef cryptLayer fill:#6c5ce7,stroke:#a29bfe,color:#dfe6e9,stroke-width:2px
    classDef netLayer   fill:#636e72,stroke:#b2bec3,color:#dfe6e9,stroke-width:2px

    S1["<b>User Keystrokes</b><br/>byte[]"]:::appLayer
    S2["<b>Protobuf Encode</b><br/>ClientBuffers.UserMessage<br/>→ TransportBuffers.Instruction"]:::protoLayer
    S3["<b>Fragment + zlib Compress</b><br/>fragment header + payload"]:::fragLayer
    S4["<b>SSP Datagram</b><br/>12-byte nonce · timestamps"]:::sspLayer
    S5["<b>AES-128-OCB Encrypt</b><br/>SspCipher.encrypt()"]:::cryptLayer

    NET(["<b>Network  ·  UDP / IP</b>"]):::netLayer

    R5["<b>AES-128-OCB Decrypt</b><br/>verify + decrypt"]:::cryptLayer
    R4["<b>SSP Datagram Parse</b><br/>nonce · timestamps · payload"]:::sspLayer
    R3["<b>Fragment Reassembly</b><br/>defragment + zlib decompress"]:::fragLayer
    R2["<b>Protobuf Decode</b><br/>HostBuffers.HostMessage<br/>→ host bytes + resize"]:::protoLayer
    R1["<b>Terminal Update</b><br/>Framebuffer · ANSI render"]:::appLayer

    S1 -->|"Sending  ↓"| S2
    S2 --> S3 --> S4 --> S5
    S5 -->|"UDP Send"| NET
    NET -->|"UDP Receive"| R5
    R5 --> R4 --> R3 --> R2
    R2 -->|"Receiving  ↓"| R1
